<?xml version="1.0"?>
<robot name="floating_frame">


<link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.041666666666667"  ixy="0.0"  ixz="0.0" iyy="0.041666666666667" iyz="0.0" izz="0.041666666666667" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </visual> 
    
    <collision>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>           
    </collision>

</link>


  <link name="world"/>
  <joint name="reference" type="floating">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

</robot>



